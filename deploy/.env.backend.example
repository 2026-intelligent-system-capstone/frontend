ENV=prod
ENVIRONMENT=prod

APP_NAME=Dialearn
APP_DESCRIPTION='Conversational AI learning competency assessment platform'
APP_VERSION=0.1.0
API_PREFIX=/api
DOCS_URL=
REDOC_URL=
OPENAPI_URL=

ALGORITHM=HS256
ACCESS_TOKEN_SECRET_KEY=change-me-long-random-secret
REFRESH_TOKEN_SECRET_KEY=change-me-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080
ACCESS_TOKEN_COOKIE_NAME=access_token
REFRESH_TOKEN_COOKIE_NAME=refresh_token
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=none

R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_REGION_NAME=auto

OPENAI_API_KEY=change-me
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=alloy
OPENAI_REALTIME_SECRET_EXPIRE_SECONDS=600

DEBUG=false
SQLALCHEMY_ECHO=false
FRONTEND_CORS_ORIGIN=["https://dialearn.presso.ac"]
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DEBUG=false

DATABASE_URL=postgresql+asyncpg://postgres:change-me@postgres:5432/dialearn
VALKEY_URL=redis://valkey:6379/0
